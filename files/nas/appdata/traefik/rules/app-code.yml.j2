http:
  routers:
    code-rtr:
      tls: "true"
      rule: "Host(`code.{{ domain_name }}`)"
      entryPoints:
        - websecure
      middlewares:
        - chain-oauth-admin
      service: code-svc
  services:
    code-svc:
      loadBalancer:
        servers:
          - url: "http://{{ code_ip }}:8080"
  