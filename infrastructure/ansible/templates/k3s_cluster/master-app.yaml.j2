apiVersion: argoproj.io/v1alpha1
kind: Application
metadata:
  name: master-app
  namespace: argocd
spec:
  project: default
  source:
    repoURL: 'https://github.com/jeottesen/server-config.git'
    path: apps-registry
    targetRevision: HEAD
  destination:
    name: in-cluster
    server: ''
    namespace: argocd
  syncPolicy:
    automated:
      prune: false
      selfHeal: false
    syncOptions:
      - CreateNamespace=true