#cloud-config
users:
  - name: "{{ primary_user }}"
    groups: sudo
    shell: /bin/bash
    sudo: ALL=(ALL) NOPASSWD:ALL
    lock_passwd: false
    hashed_passwd: "{{ primary_user_pass_encoded }}"
    ssh_authorized_keys:
      - "{{ ssh_identity_key }}"
      - "{{ ssh_ansible_identity_key }}"

package_update: true
package_upgrade: true
packages:
  - qemu-guest-agent

packages:
  - qemu-guest-agent
  - net-tools
  - curl
runcmd:
  - systemctl enable qemu-guest-agent
  - systemctl start qemu-guest-agent
  - echo "done" > /tmp/cloud-config.done