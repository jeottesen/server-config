http:
  routers:
    plex-rtr:
      rule: "Host(`plex.{{ domain_name }}`)"
      entryPoints:
        - websecure
      middlewares:
        - chain-no-auth
      service: plex-svc
  services:
    plex-svc:
      loadBalancer:
        serversTransport: "isv-transport@file"
        servers:
          - url: "https://plex.direct:32400/"
