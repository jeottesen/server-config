  "version": "2.0.0",
  "tasks": [
    {
      "label": "Ansible: Run nas - Tag: docker-compose",
      "type": "shell",
      "command": "ansible-playbook setup-nas.yml --tag docker-compose",
      "group": {
        "kind": "build"
      },
      "options": {
        "cwd": "${workspaceFolder}/infrastructure/ansible"
      },
      "problemMatcher": []
    },
    {
      "label": "Ansible: Run nas - Tag: docker-compose, Skip-Tag: compose-setup",
